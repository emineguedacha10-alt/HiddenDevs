-- Roblox services used
local PathService = game:GetService("PathfindingService") -- For NPC pathfinding
local ChatService = game:GetService("Chat") -- To make NPC speak
local TweenService = game:GetService("TweenService") -- For smooth movements or rotations
local Players = game:GetService("Players") -- Access all players
local SoundService = game:GetService("SoundService") -- For playing sounds

-- NPC references
local Civilian = workspace.Civilian -- The NPC model
local Hum = Civilian.Humanoid -- The NPC's humanoid to control movement and animations

-- Load main animations
local AnimTrack = Hum.Animator:LoadAnimation(script.Animation) -- Greeting or action animation
local AnimTrackSleep = Hum.Animator:LoadAnimation(script.SleepAnimation) -- Sleeping animation
AnimTrackSleep.Looped = true -- Loop the sleep animation

-- Random emote animations
local randomEmote1 = Hum.Animator:LoadAnimation(script.a)
local randomEmote2 = Hum.Animator:LoadAnimation(script.b)
local randomEmote3 = Hum.Animator:LoadAnimation(script.c)
local anims = {randomEmote1, randomEmote2, randomEmote3} -- Table for choosing random emotes

-- Waypoints for NPC movement
local Wayparts = workspace.Wayparts:GetChildren()

-- Track if NPC is idle
local IsIdle = true

-- Random chat phrases for the NPC
local phrases = {
    "Hmm... where should I go next?",
    "What a calm day.",
    "I feel like walking more!",
    "Maybe I should take a rest soon...",
    "Walking around is fun!",
    "I love this place!",
    "Maybe I should sit for a while.",
    "The sun is shining bright today.",
    "I hope I see someone I know.",
    "What a wonderful world!"
}

-- Sound list
local soundList = {
    "Wow.",
    "Dog Sleeping Meme ",
    "Bye - Pizza Place",
    "GreetingTone",
    "Laugh1",
    "Laugh2"
}

-- Function to play a random sound
function PlayRandomSound()
    local snd = soundList[math.random(1,#soundList)] -- Pick a random sound
    if SoundService:FindFirstChild(snd) then
        SoundService[snd]:Play() -- Play it if it exists
    end
end

-- Function to turn NPC toward a player
function Turn(player)
    local Tween = TweenService:Create(
        Civilian.HumanoidRootPart,
        TweenInfo.new(0.3), -- Rotation duration
        {CFrame = CFrame.new(Civilian.HumanoidRootPart.Position, player.Character.HumanoidRootPart.Position)} -- Face player
    )
    Tween:Play() -- Execute the rotation
end

-- Create a path avoiding forbidden zones
local NewPath = PathService:CreatePath({
    ["Costs"] = {["ForbiddenZone"] = math.huge} -- Makes ForbiddenZone impossible to walk through
})

-- Function to make NPC speak randomly
function SpeakRandom()
    if math.random(1,5) == 3 then -- 20% chance
        local phrase = phrases[math.random(1,#phrases)]
        ChatService:Chat(Civilian.Head, phrase, Enum.ChatColor.White)
    end
end

-- Main function for NPC movement
function GotoAPath()
    if IsIdle == false then return end -- Do nothing if NPC is busy
    IsIdle = false -- Mark NPC as busy

    -- Choose a random destination from waypoints
    local targetPos = Wayparts[math.random(1,#Wayparts)].Position + Vector3.new(math.random(1,5),0,math.random(1,5))
    NewPath:ComputeAsync(Civilian.HumanoidRootPart.Position, targetPos) -- Compute path

    -- Move through waypoints
    local Waypoints = NewPath:GetWaypoints()
    for i, waypoint in pairs(Waypoints) do
        Hum:MoveTo(waypoint.Position)
        Hum.MoveToFinished:Wait() -- Wait until NPC reaches the waypoint
    end

    -- Look around after moving
    for i = 1, 4 do
        Civilian.HumanoidRootPart.CFrame = Civilian.HumanoidRootPart.CFrame * CFrame.Angles(0, math.rad(90), 0)
        task.wait(0.4)
    end

    -- Play a random emote animation
    if math.random(1, 4) == 2 then
        local anim = anims[math.random(1,#anims)]
        if not anim.IsPlaying then
            anim:Play()
            task.wait(2)
            anim:Stop()
        end
    end

    SpeakRandom() -- NPC speaks randomly

    -- Random interaction with Seat or Bed
    if math.random(1,3) == 1 then
        local randomnumber = math.random(1,2) -- Decide to sit or sleep
        for i,v in pairs(workspace:GetDescendants()) do
            if v.Name == "Seat" and randomnumber == 1 then
                MoveToObject(v) -- Move NPC to seat
                v:Sit(Hum) -- Sit the NPC
                PlayRandomSound() -- Play a sound
                ChatService:Chat(Civilian.Head,"What a beautiful day... 😊",Enum.ChatColor.Green)
                task.wait(4)
                Hum.Jump = true -- Jump to stand up
                IsIdle = true
                break
            elseif v.Name == "Bed" and randomnumber == 2 then
                MoveToObject(v) -- Move NPC to bed
                v:Sit(Hum)
                AnimTrackSleep:Play() -- Play sleep animation
                PlayRandomSound()
                ChatService:Chat(Civilian.Head,"GoodNight ...",Enum.ChatColor.White)
                task.wait(4)
                AnimTrackSleep:Stop()
                Hum.Jump = true
                IsIdle = true
                break
            end
        end
    end

    PlayRandomSound() -- Play ending sound
    IsIdle = true -- Mark NPC as idle
end

-- Utility function to move NPC to an object
function MoveToObject(obj)
    NewPath:ComputeAsync(Civilian.HumanoidRootPart.Position, obj.Position) -- Compute path
    local Waypoints = NewPath:GetWaypoints()
    for i,waypoint in pairs(Waypoints) do
        Hum:MoveTo(waypoint.Position)
        task.wait(0.2)
    end
end

-- Player detection using raycasting
task.spawn(function()
    local cooldown = false -- Prevent repeated greetings
    while true do
        task.wait(0.5)
        if cooldown == false then
            local Rayc = workspace:Raycast(Civilian.Head.Position, Civilian.Head.CFrame.LookVector*50)
            if Rayc ~= nil then
                for i, player in pairs(Players:GetChildren()) do
                    if player.Name == Rayc.Instance.Parent.Parent.Name and IsIdle == true then
                        AnimTrack:Play() -- Play greeting animation
                        cooldown = true
                        task.spawn(function()
                            task.wait(1)
                            Turn(player) -- Turn toward player
                        end)
                        ChatService:Chat(Civilian.Head,"Hello ".. player.Name,Enum.ChatColor.White)
                        Civilian.HumanoidRootPart.AudioTextToSpeech.Text = "Hello.."..player.DisplayName
                        Civilian.HumanoidRootPart.AudioTextToSpeech:Play()
                        task.wait(9)
                        cooldown = false
                    end
                end
            end
        end
    end
end)

-- Bed touch detection for sleeping
workspace.Bed.Touched:Connect(function(hit)
    local hita = hit.Parent
    if hita.Parent:IsA("Model") then
        local anim = hita.Humanoid.Animator:LoadAnimation(script.SleepAnimation)
        hita.Humanoid.Jumping:Connect(function() -- Stop sleep animation if player jumps
            anim:Stop()
        end)
        anim:Play()	
    end
end)

-- Continuous random movement loop
while true do
    task.wait(8) -- Wait 8 seconds between movements
    task.spawn(function()
        GotoAPath() -- Move NPC randomly
    end)
end

-- Extra random behaviors for idle state
function WaveHand()
    local anim = Hum.Animator:LoadAnimation(script.Wave)
    anim:Play()
    task.wait(2)
    anim:Stop()
end

function NodHead()
    local anim = Hum.Animator:LoadAnimation(script.Nod)
    anim:Play()
    task.wait(1.5)
    anim:Stop()
end

function DanceRandom()
    local anim = anims[math.random(1,#anims)]
    anim:Play()
    task.wait(3)
    anim:Stop()
end

-- Idle behavior loop
task.spawn(function()
    while true do
        if IsIdle == true then
            if math.random(1,5) == 3 then
                WaveHand()
            elseif math.random(1,5) == 2 then
                NodHead()
            else
                DanceRandom()
            end
        end
        task.wait(math.random(5,10)) -- Wait 5–10 seconds before next idle action
    end
end)
